# Executor Manager local development (uv run python -m app.main)
# Only overrides that differ from the code defaults are listed.

# Backend URL — use localhost when running backend via uvicorn alongside EM
BACKEND_URL=http://localhost:8000
# Callback URL must be reachable from executor containers
CALLBACK_BASE_URL=http://host.docker.internal:8001

INTERNAL_API_TOKEN=dev-internal-token
CALLBACK_TOKEN=dev-callback-token

# Executor containers are accessed through the host
EXECUTOR_PUBLISHED_HOST=localhost

# Workspace root for executor sandbox directories
WORKSPACE_ROOT=/tmp/poco_workspace

# S3-compatible storage (RustFS / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=poco
S3_SECRET_KEY=poco-secret
S3_BUCKET=poco

# Executor image — prefer locally built images over remote ones
EXECUTOR_PREFER_LOCAL_IMAGE=true
# Tag must match your local build (docker images | grep poco-executor)
EXECUTOR_LOCAL_IMAGE=poco-executor:lite
EXECUTOR_LOCAL_BROWSER_IMAGE=poco-executor:full

# LLM (passed through to executor containers)
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# DEFAULT_MODEL=claude-sonnet-4-20250514
