APP_NAME=OpenCoWork Backend
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
# Save logs to local files for incident forensics (stdout is still enabled).
LOG_TO_FILE=true
LOG_DIR=./logs
# How many rotated log files to keep (daily rotation).
LOG_BACKUP_COUNT=14
# When true, SQL statements may be logged (default: false; params are hidden).
LOG_SQL=false
# Default: false to avoid duplicate access logs (app emits request logs).
UVICORN_ACCESS_LOG=false

HOST=0.0.0.0
PORT=8000

# Database URL (PostgreSQL)
# Disable libpq GSS/Kerberos negotiation for local development to avoid
# startup hangs on macOS when no reachable KDC is available.
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres?gssencmode=disable&connect_timeout=5

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SECRET_KEY=change-this-secret-key-in-production
INTERNAL_API_TOKEN=change-this-token-in-production

# Browser auth session cookie name (use __Host-poco_session in HTTPS production)
AUTH_COOKIE_NAME=poco_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_DAYS=30
OAUTH_SESSION_COOKIE_NAME=poco_oauth
# Auth mode:
# - oauth_required: require OAuth login; if no provider is configured, show setup-required state.
# - oauth_optional: require OAuth when any provider is configured, otherwise fall back to single-user mode.
# - single_user: always skip OAuth and use the configured single-user identity.
AUTH_MODE=oauth_required
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Feishu / Lark OAuth login. FEISHU_OAUTH_REGION: cn (Feishu China) or global (Lark).
FEISHU_OAUTH_CLIENT_ID=
FEISHU_OAUTH_CLIENT_SECRET=
FEISHU_OAUTH_REGION=cn
FRONTEND_PUBLIC_URL=http://localhost:3000
FRONTEND_DEFAULT_LANG=zh

# Executor Manager (schedule source of truth)
EXECUTOR_MANAGER_URL=http://localhost:8001

# Local filesystem access
# Set to "cloud" to disable local directory mounting in the UI.
DEPLOYMENT_MODE=local

IM_EVENT_DISPATCH_ENABLED=false
IM_EVENT_DISPATCH_INTERVAL_SECONDS=0.5
IM_EVENT_DISPATCH_BATCH_SIZE=20
IM_EVENT_DISPATCH_LEASE_SECONDS=30

# Embedded IM providers
FEISHU_ENABLED=false
FEISHU_STREAM_ENABLED=true
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_BASE_URL=https://open.feishu.cn
# Optional: set one or more bot identities so group chats only trigger when @this bot.
# FEISHU_BOT_USER_ID=
# FEISHU_BOT_OPEN_ID=
# FEISHU_BOT_UNION_ID=
# FEISHU_BOT_NAME=

# Mem0 (memory)
MEM0_ENABLED=false
# Shared OpenAI settings for mem0 (and other OpenAI integrations).
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_AUDIO_TRANSCRIPTION_MODEL=whisper-1
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3
SILICONFLOW_TIMEOUT_SECONDS=15
MAX_AUDIO_UPLOAD_SIZE_MB=25
SKILLSMP_API_KEY=
SKILLSMP_BASE_URL=https://skillsmp.com
SKILLSMP_TIMEOUT_SECONDS=10
MEM0_VECTOR_PROVIDER=pgvector
# In docker compose with profile `mem0`: mem0-postgres
# In local host mode: localhost with port 8432
MEM0_POSTGRES_HOST=mem0-postgres
MEM0_POSTGRES_PORT=5432
MEM0_POSTGRES_DB=postgres
MEM0_POSTGRES_USER=postgres
MEM0_POSTGRES_PASSWORD=postgres
MEM0_POSTGRES_COLLECTION_NAME=memories
MEM0_GRAPH_PROVIDER=neo4j
# In docker compose with profile `mem0`: bolt://mem0-neo4j:7687
# In local host mode: bolt://localhost:8687
MEM0_NEO4J_URI=bolt://mem0-neo4j:7687
MEM0_NEO4J_USERNAME=neo4j
MEM0_NEO4J_PASSWORD=mem0graph
# MEM0_MEMGRAPH_URI=bolt://localhost:7687
# MEM0_MEMGRAPH_USERNAME=memgraph
# MEM0_MEMGRAPH_PASSWORD=mem0graph
MEM0_LLM_MODEL=gpt-4.1-nano-2025-04-14
MEM0_EMBEDDER_MODEL=text-embedding-3-small
MEM0_EMBEDDING_DIMS=1024
MEM0_HISTORY_DB_PATH=/tmp/poco/memory/history.db
