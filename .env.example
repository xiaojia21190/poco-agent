# =============================================================================
# Poco Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and configure the values below.
# Variables with defaults can be omitted; required ones are marked as such.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Model API Configuration (Anthropic-compatible)
# -----------------------------------------------------------------------------
# Configure model API key (works with Anthropic official or Anthropic-compatible endpoints).
# Anthropic official credentials: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: API base URL.
# - Anthropic official default: https://api.anthropic.com
# - Anthropic-compatible services: set provider endpoint (for example a proxy/gateway URL)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Default model ID to use (must match your endpoint/provider)
# DEFAULT_MODEL=claude-sonnet-4-20250514

# Optional: Allowed models for UI selection (JSON array only)
# Example:
# MODEL_LIST=["claude-sonnet-4-20250514","claude-opus-4-20250514"]

# -----------------------------------------------------------------------------
# SECURITY: CHANGE THESE IN PRODUCTION
# -----------------------------------------------------------------------------
# Secret key for backend JWT signing
BACKEND_SECRET_KEY=change-this-secret-key-in-production

# Token for internal API communication between services
INTERNAL_API_TOKEN=change-this-token-in-production

# Token for executor callbacks to manager
CALLBACK_TOKEN=change-this-token-in-production

# -----------------------------------------------------------------------------
# Service Ports (Optional)
# -----------------------------------------------------------------------------
# FRONTEND_PORT=3000
# BACKEND_PORT=8000
# EXECUTOR_MANAGER_PORT=8001
# POSTGRES_PORT=5432
# S3_PORT=9000
# S3_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Database (Optional - defaults are usually fine)
# -----------------------------------------------------------------------------
# POSTGRES_DB=poco
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Mem0 Memory (Optional - disabled by default)
# -----------------------------------------------------------------------------
# Enable memory APIs in backend
# MEM0_ENABLED=false
# Shared OpenAI settings for mem0 (and other OpenAI integrations)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# MEM0_VECTOR_PROVIDER=pgvector
# MEM0_POSTGRES_HOST=mem0-postgres
# MEM0_POSTGRES_PORT=5432
# MEM0_POSTGRES_DB=postgres
# MEM0_POSTGRES_USER=postgres
# MEM0_POSTGRES_PASSWORD=postgres
# MEM0_POSTGRES_COLLECTION_NAME=memories
# MEM0_GRAPH_PROVIDER=neo4j
# MEM0_NEO4J_URI=bolt://mem0-neo4j:7687
# MEM0_NEO4J_USERNAME=neo4j
# MEM0_NEO4J_PASSWORD=mem0graph
# MEM0_LLM_MODEL=gpt-4.1-nano-2025-04-14
# MEM0_EMBEDDER_MODEL=text-embedding-3-small
# MEM0_EMBEDDING_DIMS=1024
# MEM0_HISTORY_DB_PATH=/tmp/poco/memory/history.db
# Optional exposed ports for `docker compose --profile mem0 up`
# MEM0_POSTGRES_EXPOSE_PORT=8432
# MEM0_NEO4J_HTTP_PORT=8474
# MEM0_NEO4J_BOLT_PORT=8687

# -----------------------------------------------------------------------------
# S3-Compatible Storage (Optional - defaults are usually fine for local dev)
# -----------------------------------------------------------------------------
# RUSTFS_DATA_DIR=./oss_data
# S3_ACCESS_KEY=poco
# S3_SECRET_KEY=poco-secret
# S3_BUCKET=poco
# S3_REGION=us-east-1
# S3_ENDPOINT=http://rustfs:9000
# S3_PUBLIC_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
#
# Cloudflare R2 example (bucket must already exist):
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_PUBLIC_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=false

# -----------------------------------------------------------------------------
# Logging (Optional)
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# LOG_TO_FILE=false
# LOG_DIR=./logs
# LOG_BACKUP_COUNT=14
# LOG_SQL=false
# UVICORN_ACCESS_LOG=false

# -----------------------------------------------------------------------------
# Executor Manager (Optional)
# -----------------------------------------------------------------------------
# Maximum number of tasks to run concurrently
# MAX_CONCURRENT_TASKS=5

# Local filesystem access
# Executor Manager now resolves local mounts with direct bind mounts only.
# Docker resolves bind source paths from the host filesystem when the manager
# starts executor containers through `/var/run/docker.sock`.
#
# Backend still exposes `/api/v1/filesystem/support` for the frontend capability
# probe. These variables affect that response only and do not change manager-side
# mount resolution.
# DEPLOYMENT_MODE=local
# Optional frontend-facing helper status override returned by the backend.
# LOCAL_FILESYSTEM_HELPER_STATUS=available
# LOCAL_FILESYSTEM_HELPER_MESSAGE=

# Browser / Desktop (Optional)
# Default desktop viewport for browser-enabled runs (Playwright MCP).
# POCO_BROWSER_VIEWPORT_SIZE=1366x768
# Timezone passed through to executor containers.
# EXECUTOR_TIMEZONE=Asia/Shanghai

# Task polling configuration
# TASK_PULL_ENABLED=true
# TASK_PULL_INTERVAL_SECONDS=2
# TASK_CLAIM_LEASE_SECONDS=900

# Workspace cleanup and archival
# WORKSPACE_CLEANUP_ENABLED=false
# WORKSPACE_ARCHIVE_ENABLED=true
# WORKSPACE_ARCHIVE_DAYS=7
# WORKSPACE_IGNORE_DOT_FILES=true

# -----------------------------------------------------------------------------
# Embedded IM Integration (Optional)
# -----------------------------------------------------------------------------
# IM is embedded in the backend service. No separate `im` container is needed.
# Set IM_EVENT_DISPATCH_ENABLED=true to consume backend outbox events and push
# model output / terminal notifications / user-input requests back to IM.
#
# IM_EVENT_DISPATCH_ENABLED=false
# BACKEND_USER_ID=default
# FRONTEND_PUBLIC_URL=http://localhost:3000
# FRONTEND_DEFAULT_LANG=zh
#
# Telegram (required for Telegram integration)
# TELEGRAM_BOT_TOKEN=
# Optional secret token for Telegram webhook verification
# TELEGRAM_WEBHOOK_SECRET_TOKEN=
#
# DingTalk bot integration
# DINGTALK_ENABLED=true
# DINGTALK_WEBHOOK_TOKEN=
# DingTalk Stream Mode (recommended for inbound messages without public webhook)
# DINGTALK_STREAM_ENABLED=true
# Optional: subscribe all DingTalk events (EVENT topic="*"), can be noisy
# DINGTALK_STREAM_SUBSCRIBE_EVENTS=false
# DingTalk OpenAPI (recommended for proactive messages via conversationId)
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=
# DINGTALK_ROBOT_CODE=
# DINGTALK_OPEN_BASE_URL=https://api.dingtalk.com
# Optional fallback outbound webhook URL
# DINGTALK_WEBHOOK_URL=
#
# Feishu bot integration
# FEISHU_ENABLED=false
# FEISHU_STREAM_ENABLED=true
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_BASE_URL=https://open.feishu.cn
# Long connection is recommended and does not need a public callback URL.
# FEISHU_VERIFICATION_TOKEN is only used in webhook fallback mode.
# Webhook fallback currently expects plaintext callbacks, so disable callback encryption.

# -----------------------------------------------------------------------------
# Container Images (Optional - override for local development)
# -----------------------------------------------------------------------------
# BACKEND_IMAGE=ghcr.io/poco-ai/poco-backend:latest
# EXECUTOR_MANAGER_IMAGE=ghcr.io/poco-ai/poco-executor-manager:latest
# EXECUTOR_IMAGE=ghcr.io/poco-ai/poco-executor:lite
# Prefer local executor images first; fall back to remote images when missing.
# EXECUTOR_PREFER_LOCAL_IMAGE=false
# EXECUTOR_LOCAL_IMAGE=poco-executor:lite-local
# Optional: executor image with desktop/browser stack (used when browser_enabled=true).
# EXECUTOR_BROWSER_IMAGE=ghcr.io/poco-ai/poco-executor:full
# EXECUTOR_LOCAL_BROWSER_IMAGE=poco-executor:full-local
# FRONTEND_IMAGE=ghcr.io/poco-ai/poco-frontend:latest

# RUSTFS_IMAGE=rustfs/rustfs:latest
# RUSTFS_INIT_IMAGE=minio/mc:latest
